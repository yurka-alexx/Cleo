@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

echo.
echo  ╔══════════════════════════════════════════╗
echo  ║      Cleo ^— Installation (Windows)      ║
echo  ╚══════════════════════════════════════════╝
echo.

set "TARGET=%USERPROFILE%\Cleo"
set "TMPZIP=%TEMP%\cleo_payload_%RANDOM%.zip"
set "TMPB64=%TEMP%\cleo_payload_%RANDOM%.b64"

REM ─── Zielordner prüfen ───────────────────────────────────────────────────
if exist "%TARGET%" (
    echo  ⚠️  Der Ordner '%TARGET%' existiert bereits.
    set /p CONFIRM="     Überschreiben? (j/n): "
    if /i "!CONFIRM!" neq "j" (
        echo  ❌ Installation abgebrochen.
        pause
        exit /b 1
    )
    rmdir /s /q "%TARGET%"
)

